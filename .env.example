# Ailogy 配置示例。复制为 .env 后按需修改；.env 不参与版本管理。
# cp .env.example .env

# ── 后端 ──
# SQLite 库文件路径（留空则用仓库根 ailogy.db）
AILOGY_DB=
# 监听地址与端口
AILOGY_HOST=127.0.0.1
AILOGY_PORT=8000
# CORS 允许来源（逗号分隔）
AILOGY_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
# 会话 cookie Secure 标志：本地 http 用 0，上线 https 置 1
AILOGY_COOKIE_SECURE=0
# 版本与仓库（关于页 / 更新检查展示）
AILOGY_VERSION=0.1.0
AILOGY_REPO=https://github.com/icloudsheep/Ailogy

# ── CLI 上报（双模式）──
# 后端地址与密钥；也可写进 ~/.config/ai-log/config.json 的 backend 段
AILOG_BACKEND_URL=http://127.0.0.1:8000
AILOG_API_KEY=
# 默认是否上报（1/0），可被 --report / --offline 覆盖
AILOG_REPORT=0
